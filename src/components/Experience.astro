---
// Experience — CREAM section. "03 — experience" / WHERE I'VE SHIPPED.
// Stokt awards-list treatment: full-width rows, 1px dividers, hover accent.
import { experience, education, certifications } from "../data/resume";
---

<section
  id="experience"
  class="scroll-mt-20 bg-(--color-cream) text-(--color-ink-on-cream)"
  aria-labelledby="experience-title"
>
  <div class="container-site py-24 md:py-32">
    <p class="eyebrow text-(--color-ink-on-cream-dim)">03 — experience</p>
    <h2 id="experience-title" class="display mt-4 text-5xl md:text-7xl lg:text-8xl">
      Where I&rsquo;ve shipped
    </h2>

    <ol class="mt-14 border-t border-(--color-line-cream) md:mt-20" role="list">
      {
        experience.map((job) => (
          <li class="group border-b border-(--color-line-cream) px-0 py-10 transition-colors duration-200 hover:bg-(--color-line-cream)/35">
            <div class="grid gap-3 md:grid-cols-12 md:items-baseline md:gap-8">
              <div class="md:col-span-8">
                <h3 class="display text-3xl transition-colors duration-200 group-hover:text-(--color-accent) md:text-4xl">
                  {job.company}
                </h3>
                <p class="mt-3 text-sm font-semibold md:text-base">{job.role}</p>
              </div>
              <p class="font-mono text-xs uppercase tracking-[0.12em] text-(--color-ink-on-cream-dim) md:col-span-4 md:text-right">
                {job.period}
                <span class="mt-1 block">{job.location}</span>
              </p>
            </div>

            <ul class="mt-6 max-w-3xl space-y-2.5 text-sm leading-relaxed text-(--color-ink-on-cream-dim)">
              {job.points.slice(0, 2).map((point) => (
                <li class="flex gap-3">
                  <span
                    aria-hidden="true"
                    class="mt-[0.45em] h-1 w-1 shrink-0 rounded-full bg-(--color-accent)"
                  />
                  {point}
                </li>
              ))}
            </ul>

            <ul class="mt-6 flex flex-wrap gap-x-5 gap-y-2" aria-label="Technologies">
              {job.tech.map((t) => (
                <li class="eyebrow text-(--color-ink-on-cream-dim)">{t}</li>
              ))}
            </ul>
          </li>
        ))
      }
    </ol>

    {/* Compact final row pair: education + certification */}
    <div class="grid gap-10 border-b border-(--color-line-cream) px-0 py-10 md:grid-cols-12 md:gap-8">
      <div class="md:col-span-8">
        <h3 class="eyebrow text-(--color-ink-on-cream-dim)">Education</h3>
        <ul class="mt-5 space-y-5">
          {
            education.map((edu) => (
              <li class="grid gap-1 md:grid-cols-12 md:items-baseline md:gap-8">
                <div class="md:col-span-8">
                  <p class="text-sm font-semibold md:text-base">{edu.school}</p>
                  <p class="mt-0.5 text-sm text-(--color-ink-on-cream-dim)">
                    {edu.degree} · {edu.note}
                  </p>
                </div>
                <p class="font-mono text-xs uppercase tracking-[0.12em] text-(--color-ink-on-cream-dim) md:col-span-4">
                  {edu.period}
                </p>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="md:col-span-4 md:text-right">
        <h3 class="eyebrow text-(--color-ink-on-cream-dim)">Certification</h3>
        <ul class="mt-5 space-y-5">
          {
            certifications.map((cert) => (
              <li>
                <p class="text-sm font-semibold md:text-base">{cert.name}</p>
                <p class="mt-0.5 font-mono text-xs uppercase tracking-[0.12em] text-(--color-ink-on-cream-dim)">
                  {cert.org}
                </p>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
