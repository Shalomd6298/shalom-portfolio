---
// Work — DESIGN.md item 4. Cream section, bento grid of the three projects.
// All copy comes from src/data/resume.ts; the dark "visual" blocks are
// hand-crafted HTML/CSS (code snippet / ASCII flow / metric tiles), no images.
import { projects } from "../data/resume";

const [gcp, aws, site] = projects;

// Visual 1 — operator CR + helm release, green/amber syntax accents
// (terminal-green is allowed inside literal code snippets per DESIGN.md).
const gcpSnippet = `<span class="text-(--color-ink-on-dark-dim)">$</span> <span class="text-[#8ae28a]">helm</span> upgrade --install platform ./charts
<span class="text-(--color-ink-on-dark-dim)">release "platform" deployed · revision 7</span>

<span class="text-[#e8c06a]">apiVersion:</span> ops.shalom.dev/v1
<span class="text-[#e8c06a]">kind:</span> DatabaseBackup
<span class="text-[#e8c06a]">spec:</span>
  <span class="text-[#e8c06a]">schedule:</span> <span class="text-[#8ae28a]">"0 3 * * *"</span>
  <span class="text-[#e8c06a]">target:</span> postgres-primary
<span class="text-[#e8c06a]">status:</span> <span class="text-[#8ae28a]">✓ Synced</span>`;

// Visual 2 — ASCII architecture flow (arrows picked out in accent).
const A = (s: string) => `<span class="text-(--color-accent)">${s}</span>`;
const awsFlow = `git push ${A("─▶")} GitHub Actions ${A("─▶")} Packer AMI
                  │
                  ${A("▼")}
           terraform apply
                  │
       ┌──────────┴───────┐
       ${A("▼")}                  ${A("▼")}
ALB ${A("─▶")} EC2 ASG          Lambda ${A("─▶")} SNS
       │                           │
       ${A("▼")}                           ${A("▼")}
   RDS · KMS                   SendGrid`;

// Visual 3 — mono metric tiles ("This Website").
const siteMetrics = [
  { value: "100", label: "lighthouse score" },
  { value: "0 kB", label: "client-side js" },
  { value: "2", label: "k3s nodes at home" },
  { value: "×2", label: "arch · amd64 + arm64" },
];
---

<section
  id="work"
  class="scroll-mt-20 bg-(--color-cream) text-(--color-ink-on-cream)"
>
  <div class="container-site py-24 md:py-32">
    <!-- Section head -->
    <header class="mb-12 md:mb-16">
      <p class="eyebrow mb-5 text-(--color-ink-on-cream-dim)">
        01 — selected work
      </p>
      <h2 class="display display-h2">
        Selected Work<span class="text-(--color-accent)">.</span>
      </h2>
    </header>

    <div class="grid gap-5 md:grid-cols-12 md:gap-6">
      <!-- ── Card 1 · GCP platform — spans 7 ───────────────────── -->
      <article
        class="group flex flex-col rounded-2xl border border-(--color-line-cream) p-5 transition-[border-color,transform] duration-200 hover:border-(--color-accent) motion-safe:hover:-translate-y-1 md:col-span-7 md:p-6"
      >
        <div
          class="mb-6 overflow-x-auto rounded-xl bg-(--color-dark) p-4 md:p-6"
          aria-hidden="true"
        >
          <p class="eyebrow mb-4 text-(--color-ink-on-dark-dim)">
            backup-operator.yaml
          </p>
          <pre
            class="font-mono text-[10px] leading-relaxed text-(--color-ink-on-dark) md:text-xs"
            set:html={gcpSnippet}
          />
        </div>

        <h3 class="display mb-3 text-2xl md:text-3xl">
          {gcp.name}
        </h3>
        <p class="mb-4 max-w-prose text-sm leading-relaxed text-(--color-ink-on-cream-dim)">
          {gcp.summary}
        </p>
        <ul class="mb-6 space-y-1.5 text-sm leading-relaxed text-(--color-ink-on-cream-dim)">
          {
            gcp.details.map((d) => (
              <li class="flex gap-2">
                <span class="text-(--color-accent)" aria-hidden="true">▸</span>
                {d}
              </li>
            ))
          }
        </ul>
        <ul class="mt-auto flex flex-wrap gap-2">
          {
            gcp.tech.map((t) => (
              <li class="rounded-full border border-(--color-line-cream) px-2.5 py-1 font-mono text-[0.65rem] tracking-[0.08em] text-(--color-ink-on-cream-dim) uppercase">
                {t}
              </li>
            ))
          }
        </ul>
      </article>

      <!-- ── Card 2 · AWS web app — spans 5 ────────────────────── -->
      <article
        class="group flex flex-col rounded-2xl border border-(--color-line-cream) p-5 transition-[border-color,transform] duration-200 hover:border-(--color-accent) motion-safe:hover:-translate-y-1 md:col-span-5 md:p-6"
      >
        <div
          class="mb-6 overflow-x-auto rounded-xl bg-(--color-dark) p-4 md:p-6"
          aria-hidden="true"
        >
          <p class="eyebrow mb-4 text-(--color-ink-on-dark-dim)">
            architecture · ascii
          </p>
          <pre
            class="font-mono text-[10px] leading-relaxed text-(--color-ink-on-dark) md:text-xs"
            set:html={awsFlow}
          />
        </div>

        <h3 class="display mb-3 text-2xl md:text-3xl">
          {aws.name}
        </h3>
        <p class="mb-4 max-w-prose text-sm leading-relaxed text-(--color-ink-on-cream-dim)">
          {aws.summary}
        </p>
        <ul class="mb-6 space-y-1.5 text-sm leading-relaxed text-(--color-ink-on-cream-dim)">
          {
            aws.details.map((d) => (
              <li class="flex gap-2">
                <span class="text-(--color-accent)" aria-hidden="true">▸</span>
                {d}
              </li>
            ))
          }
        </ul>
        <ul class="mt-auto flex flex-wrap gap-2">
          {
            aws.tech.map((t) => (
              <li class="rounded-full border border-(--color-line-cream) px-2.5 py-1 font-mono text-[0.65rem] tracking-[0.08em] text-(--color-ink-on-cream-dim) uppercase">
                {t}
              </li>
            ))
          }
        </ul>
      </article>

      <!-- ── Card 3 · This website — full width, split layout ──── -->
      <article
        class="group rounded-2xl border border-(--color-line-cream) p-5 transition-[border-color,transform] duration-200 hover:border-(--color-accent) motion-safe:hover:-translate-y-1 md:col-span-12 md:p-6 lg:grid lg:grid-cols-12 lg:items-center lg:gap-10"
      >
        <div
          class="mb-6 rounded-xl bg-(--color-dark) p-4 md:p-6 lg:col-span-6 lg:mb-0"
        >
          <p class="eyebrow mb-4 text-(--color-ink-on-dark-dim)">
            /metrics — you are here
          </p>
          <dl class="grid grid-cols-2 gap-2 md:gap-3">
            {
              siteMetrics.map((m) => (
                <div class="flex flex-col-reverse rounded-lg border border-(--color-line-dark) p-4 md:p-5">
                  {/* flex-col-reverse keeps valid dt→dd source order while
                      showing the big value above its label */}
                  <dt class="eyebrow mt-2 text-(--color-ink-on-dark-dim)">
                    {m.label}
                  </dt>
                  <dd class="display text-3xl text-(--color-accent) md:text-4xl">
                    {m.value}
                  </dd>
                </div>
              ))
            }
          </dl>
        </div>

        <div class="flex flex-col lg:col-span-6">
          <h3 class="display mb-3 text-2xl md:text-3xl">
            {site.name}
          </h3>
          <p class="mb-4 max-w-prose text-sm leading-relaxed text-(--color-ink-on-cream-dim)">
            {site.summary}
          </p>
          <ul class="mb-6 space-y-1.5 text-sm leading-relaxed text-(--color-ink-on-cream-dim)">
            {
              site.details.map((d) => (
                <li class="flex gap-2">
                  <span class="text-(--color-accent)" aria-hidden="true">▸</span>
                  {d}
                </li>
              ))
            }
          </ul>
          <ul class="flex flex-wrap gap-2">
            {
              site.tech.map((t) => (
                <li class="rounded-full border border-(--color-line-cream) px-2.5 py-1 font-mono text-[0.65rem] tracking-[0.08em] text-(--color-ink-on-cream-dim) uppercase">
                  {t}
                </li>
              ))
            }
          </ul>
        </div>
      </article>
    </div>
  </div>
</section>
