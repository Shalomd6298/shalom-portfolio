---
// Stats — DARK section. "02 — by the numbers" / PLATFORM POWERHOUSE.
// Every figure traces to src/data/resume.ts (see per-line source notes);
// cloud count + cert are derived directly from the data.
import { skills, certifications } from "../data/resume";

const cloudCount = skills.find((g) => g.group === "Cloud")?.items.length ?? 0;
const cert = certifications[0];

const stats = [
  // Proof — "resolved 500+ deprecations" (experience[0].points[0])
  { figure: "500+", label: "deprecations resolved" },
  // Proof — "Cut smoke-test execution time 30%" (experience[0].points[1])
  { figure: "30%", label: "faster test suites" },
  // Northeastern — "Supported 200+ students" (experience[1].points[0])
  { figure: "200+", label: "students supported" },
  // Johnson Controls — "Carried 24/7 on-call" (experience[2].points[3])
  { figure: "24/7", label: "on-call carried" },
  // skills "Cloud" group — AWS · Azure · GCP
  { figure: String(cloudCount), label: "clouds deep" },
  // certifications[0] — Certified Kubernetes Administrator (CNCF)
  { figure: "CKA", label: "certified k8s admin" },
];
---

<section class="bg-(--color-dark) text-(--color-ink-on-dark)" aria-labelledby="stats-title">
  <div class="container-site py-24 md:py-32">
    <p class="eyebrow text-(--color-ink-on-dark-dim)">02 — by the numbers</p>
    <h2 id="stats-title" class="display display-h2 mt-4">
      Platform powerhouse
    </h2>

    {/* gap-px over a line-colored backdrop draws the thin internal dividers */}
    <dl
      class="mt-14 grid grid-cols-2 gap-px border-y border-(--color-line-dark) bg-(--color-line-dark) md:mt-20 md:grid-cols-3"
    >
      {
        stats.map((stat) => (
          <div class="flex flex-col gap-4 bg-(--color-dark) px-4 py-10 max-md:odd:pl-0 md:px-8 md:py-14 md:nth-[3n+1]:pl-0">
            <dt class="eyebrow order-2 text-(--color-ink-on-dark-dim)">{stat.label}</dt>
            <dd class="display order-1 text-6xl text-(--color-accent) md:text-7xl">
              {stat.figure}
            </dd>
          </div>
        ))
      }
    </dl>

    <p class="mt-8 font-mono text-xs tracking-[0.08em] text-(--color-ink-on-dark-dim)">
      // {cert?.name} — {cert?.org}
    </p>
  </div>
</section>
