---
// Hero — the dark opening statement (DESIGN.md item 2). No terminal card, no images.
import { profile } from "../data/resume";

const eyebrow = `${profile.role} — ${profile.location}`;

// Meta row: location + the CKA & clouds highlights, pulled from data (never hardcoded).
const meta = [
  profile.location,
  profile.highlights.find((h) => h.startsWith("CKA")),
  profile.highlights.find((h) => h.includes("AWS")),
].filter(Boolean) as string[];
---

<section id="top" class="bg-(--color-dark) text-(--color-ink-on-dark)">
  <div class="container-site flex min-h-[88svh] flex-col justify-between">
    <div class="pt-16 md:pt-24">
      <p class="eyebrow text-balance text-(--color-ink-on-dark-dim)">{eyebrow}</p>

      <h1 class="display mt-6 text-[clamp(3.4rem,17vw,16rem)] md:mt-8">
        <span class="block">Keeping</span>
        <span class="block">Production</span>
        <span class="block text-(--color-accent)">Boring.</span>
      </h1>

      <p class="mt-8 max-w-prose text-base leading-relaxed text-pretty text-(--color-ink-on-dark-dim) md:mt-10 md:text-lg">
        {profile.tagline}
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-4 md:mt-12">
        <a
          href="#work"
          class="btn-solid focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-ink-on-dark)"
        >view work</a>
        <a
          href={profile.links.github}
          rel="noopener"
          class="btn-outline text-(--color-ink-on-dark) hover:bg-(--color-ink-on-dark) hover:text-(--color-dark) focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-accent)"
        >github</a>
      </div>
    </div>

    <ul
      aria-label="Quick facts"
      class="mt-16 flex flex-wrap items-center gap-x-8 gap-y-3 border-t border-(--color-line-dark) py-6 md:py-8"
    >
      {meta.map((item) => (
        <li class="eyebrow flex items-start gap-3 text-(--color-ink-on-dark-dim)">
          <span aria-hidden="true" class="mt-[0.4em] inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-(--color-accent)"></span>
          {item}
        </li>
      ))}
    </ul>
  </div>
</section>
