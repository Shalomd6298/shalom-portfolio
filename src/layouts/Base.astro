---
import "../styles/global.css";
import { profile } from "../data/resume";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = `${profile.name} — ${profile.role}`,
  description = profile.tagline,
} = Astro.props;

// JSON-LD Person schema — canonical/og:url intentionally omitted until a
// domain is chosen (tracked in issue #7).
const personSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  jobTitle: profile.role,
  email: `mailto:${profile.email}`,
  address: { "@type": "PostalAddress", addressLocality: "Boston", addressRegion: "MA" },
  sameAs: [profile.links.github, profile.links.linkedin],
  knowsAbout: ["Kubernetes", "DevOps", "AWS", "Terraform", "CI/CD", "Site Reliability Engineering"],
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={profile.name} />
    <meta name="twitter:card" content="summary" />
    <meta name="theme-color" content="#0e0e0c" />
    <meta name="author" content={profile.name} />
    <script type="application/ld+json" set:html={personSchema} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
