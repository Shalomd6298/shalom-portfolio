---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import { profile, experience, projects, skills, education, certifications } from "../data/resume";
---

<Base>
  <Nav />
  <main>
    <Hero />

    <Section id="experience" num="01" title="Experience">
      <ol class="space-y-10 border-l border-(--color-line) pl-6 md:pl-8">
        {experience.map((job) => (
          <li class="relative">
            <span class="absolute -left-[31px] top-1.5 h-2.5 w-2.5 rounded-full border-2 border-(--color-accent) bg-(--color-bg) md:-left-[39px]"></span>
            <div class="flex flex-wrap items-baseline justify-between gap-x-4">
              <h3 class="text-lg font-semibold text-white">
                {job.role} <span class="text-(--color-accent)">@ {job.company}</span>
              </h3>
              <p class="font-mono text-xs text-(--color-ink-faint)">{job.period} · {job.location}</p>
            </div>
            <ul class="mt-3 space-y-2">
              {job.points.map((p) => (
                <li class="flex gap-3 text-sm leading-relaxed text-(--color-ink-dim)">
                  <span class="mt-1 text-(--color-accent)">▸</span>
                  <span>{p}</span>
                </li>
              ))}
            </ul>
            <div class="mt-3 flex flex-wrap gap-2">
              {job.tech.map((t) => <span class="tag">{t}</span>)}
            </div>
          </li>
        ))}
      </ol>
    </Section>

    <Section id="projects" num="02" title="Things I've Built">
      <div class="grid gap-5 md:grid-cols-2">
        {projects.map((proj, i) => (
          <article
            class:list={[
              "card group p-6 transition-colors hover:border-(--color-accent-dim)",
              i === 2 && "md:col-span-2",
            ]}
          >
            <div class="mb-3 flex items-center justify-between">
              <span class="font-mono text-xs text-(--color-accent)">{`proj-0${i + 1}`}</span>
              {i === 2 && <span class="tag">← you are here</span>}
            </div>
            <h3 class="text-base font-semibold text-white group-hover:text-(--color-accent)">
              {proj.name}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-(--color-ink-dim)">{proj.summary}</p>
            <ul class="mt-3 space-y-1.5">
              {proj.details.map((d) => (
                <li class="flex gap-2 text-sm text-(--color-ink-dim)">
                  <span class="text-(--color-accent)">▸</span>
                  <span>{d}</span>
                </li>
              ))}
            </ul>
            <div class="mt-4 flex flex-wrap gap-2">
              {proj.tech.map((t) => <span class="tag">{t}</span>)}
            </div>
          </article>
        ))}
      </div>
    </Section>

    <Section id="skills" num="03" title="Toolbox">
      <div class="card divide-y divide-(--color-line)">
        {skills.map((s) => (
          <div class="grid gap-2 px-6 py-4 md:grid-cols-[220px_1fr] md:items-center">
            <h3 class="font-mono text-xs font-medium uppercase tracking-wider text-(--color-ink-faint)">
              {s.group}
            </h3>
            <div class="flex flex-wrap gap-2">
              {s.items.map((i) => <span class="tag">{i}</span>)}
            </div>
          </div>
        ))}
      </div>

      <div class="mt-8 grid gap-5 md:grid-cols-2">
        <div class="card p-6">
          <h3 class="mb-4 font-mono text-xs uppercase tracking-wider text-(--color-ink-faint)">Education</h3>
          <ul class="space-y-4">
            {education.map((e) => (
              <li>
                <p class="text-sm font-semibold text-white">{e.school}</p>
                <p class="text-sm text-(--color-ink-dim)">{e.degree}</p>
                <p class="font-mono text-xs text-(--color-ink-faint)">{e.period} · {e.note}</p>
              </li>
            ))}
          </ul>
        </div>
        <div class="card p-6">
          <h3 class="mb-4 font-mono text-xs uppercase tracking-wider text-(--color-ink-faint)">Certifications</h3>
          {certifications.map((c) => (
            <div class="flex items-center gap-3">
              <span class="text-2xl">☸</span>
              <div>
                <p class="text-sm font-semibold text-white">{c.name}</p>
                <p class="font-mono text-xs text-(--color-ink-faint)">{c.org}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Section>

    <Section id="contact" num="04" title="Get In Touch">
      <div class="mx-auto max-w-xl text-center">
        <p class="leading-relaxed text-(--color-ink-dim)">
          I'm open to DevOps, SRE, and platform engineering roles. If you're building something
          that needs to stay up, let's talk.
        </p>
        <a
          href={`mailto:${profile.email}`}
          class="mt-8 inline-block rounded-md border border-(--color-accent-dim) px-6 py-3 font-mono text-sm text-(--color-accent) transition-colors hover:bg-(--color-accent)/10"
        >
          {profile.email}
        </a>
      </div>
    </Section>
  </main>

  <footer class="border-t border-(--color-line) py-8">
    <div class="container-site flex flex-col items-center gap-2 text-center">
      <p class="font-mono text-xs text-(--color-ink-faint)">
        built with <a href="https://astro.build" class="link-accent">astro</a> ·
        served from a <span class="text-(--color-accent)">2-node k3s cluster</span> in my homelab
      </p>
      <p class="font-mono text-xs text-(--color-ink-faint)">
        <a href={profile.links.github} class="link-accent">github</a> ·
        <a href={profile.links.linkedin} class="link-accent">linkedin</a> ·
        <a href={`mailto:${profile.email}`} class="link-accent">email</a>
      </p>
    </div>
  </footer>
</Base>
